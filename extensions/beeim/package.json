{
  "name": "@bee/openclaw-beeim",
  "version": "1.0.12",
  "description": "OpenClaw BeeIM channel plugin (网易小蜜蜂 IM)",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "type": "module",
  "dependencies": {
    "@yxim/nim-bot": "^10.9.78"
  },
  "devDependencies": {
    "openclaw": ">=2026.3.30",
    "zod": "^4.0.0"
  },
  "bundledDependencies": [
    "@yxim/nim-bot"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "beeim",
      "label": "BeeIM",
      "selectionLabel": "BeeIM (网易小蜜蜂 IM)",
      "docsPath": "/channels/beeim",
      "docsLabel": "beeim",
      "blurb": "BeeIM 网易小蜜蜂 IM 即时通讯。",
      "aliases": [
        "bee-im",
        "netease",
        "yunxin"
      ],
      "order": 80
    },
    "install": {
      "npmSpec": "@bee/openclaw-beeim",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.30"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    }
  }
}
