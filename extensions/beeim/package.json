{
  "name": "@openclaw/beeim",
  "version": "1.0.0",
  "description": "OpenClaw BeeIM channel plugin (网易云信 IM)",
  "type": "module",
  "dependencies": {
    "@yxim/nim-bot": "^10.9.78",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.30"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "beeim",
      "label": "BeeIM",
      "selectionLabel": "BeeIM (网易云信 IM)",
      "docsPath": "/channels/beeim",
      "docsLabel": "beeim",
      "blurb": "BeeIM 网易云信 IM 即时通讯。",
      "aliases": [
        "bee-im",
        "netease",
        "yunxin"
      ],
      "order": 80
    },
    "install": {
      "npmSpec": "@openclaw/beeim",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.30"
    },
    "bundle": {
      "stageRuntimeDependencies": true
    }
  }
}
